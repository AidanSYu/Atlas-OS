{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "cmd /c npm.cmd --prefix src/frontend run build",
    "beforeDevCommand": "cmd /c npm.cmd --prefix src/frontend run dev",
    "devPath": "http://localhost:3001",
    "distDir": "../frontend/out"
  },
  "package": {
    "productName": "Atlas",
    "version": "2.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "sidecar": true,
        "scope": [
          {
            "name": "atlas-backend",
            "sidecar": true
          }
        ]
      },
      "path": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": [
          "$APP/**",
          "$RESOURCE/**"
        ]
      },
      "dialog": {
        "all": true
      },
      "window": {
        "all": true
      },
      "process": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Productivity",
      "copyright": "Copyright 2024 Atlas Team",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.atlas.knowledge",
      "longDescription": "Atlas is an AI-native knowledge management system that combines vector search, knowledge graphs, and local LLMs for intelligent document retrieval and analysis.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [
        "resources/*"
      ],
      "shortDescription": "AI-Native Knowledge Management",
      "targets": [
        "nsis"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "dangerousDisableAssetCspModification": true,
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "Atlas - Agentic RAG Knowledge Engine",
        "width": 1400,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false
      }
    ]
  }
}
