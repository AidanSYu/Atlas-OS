{
  "schema_version": "1.0",
  "name": "predict_properties",
  "version": "0.1.0",
  "description": "Calculate RDKit molecular properties such as MW, LogP, TPSA, HBD, HBA, QED, and Lipinski flags.",
  "entry_point": "wrapper.py",
  "priority": 60,
  "tags": ["chemistry", "rdkit", "descriptors"],
  "input_schema": {
    "type": "object",
    "properties": {
      "smiles": {
        "type": "string",
        "description": "SMILES representation of a molecule."
      },
      "smiles_list": {
        "type": "array",
        "items": {"type": "string"},
        "description": "Optional batch mode list of SMILES strings."
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "properties": {"type": "array", "items": {"type": "object"}},
      "summary": {"type": "string"}
    }
  }
}
