# Project Atlas .gitignore
# ===========================

# --- Large AI Models & Data ---
/models/
models/*.gguf
models/*.bin
*.gguf
*.pt
*.pth
*.onnx
*.hdf5
*.csv.gz
src/backend/test_output.txt

# Raw SECOM download cache (derived CSVs under test_docs/manufacturing/ ARE tracked)
test_docs/fetch/cache/

# --- Local Config (machine-specific paths) ---
config.yml
.claude/settings.local.json
.claude/worktrees/

# --- Local Analysis & Scratch Files ---
benchmark/
check_orphans.py
orphans.txt
orphans_result.json
test_minimal.py
test_model.py
test_output.txt
src/backend/app/services/plugins/*-AidanYu.py

# --- Fetched dataset intermediate caches (VisA parquet shards, etc.) ---
test_docs/fetch/cache/
*.parquet

# --- TypeScript Build Cache ---
tsconfig.tsbuildinfo
*.tsbuildinfo

# ===========================

# --- Secrets & Environment ---
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
tools/keys/*

# --- Dependencies ---
node_modules/
__pycache__/
.venv/
env/
venv/
*.egg-info/

# --- Build Artifacts ---
dist/
build/
out/
.next/
src-tauri/target/
src/tauri/target/

# --- Tauri Resources & Binaries ---
src-tauri/resources/*
!src-tauri/resources/README.md
src/tauri/resources/*
!src/tauri/resources/README.md
src/tauri/resources/atlas-backend/
src-tauri/binaries/*
src/tauri/binaries/*

# --- IDE & System ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.tmp

# --- Aider / AI Tools ---
.aider*
!.aider.conf.yml
!.aiderignore

# --- Database ---
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
data/
qdrant_storage/

# --- Installers (Whitelisted) ---
# Ignore all executables by default...
*.exe
*.msi
*.dmg
*.app

# ...but allow them in the installers folder for distribution
!installers/*.exe
!installers/*.msi
!installers/*.dmg
