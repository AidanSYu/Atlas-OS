# ===========================
# Project Atlas .gitignore
# ===========================

# --- Secrets & Environment ---
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
tools/keys/*

# --- Dependencies ---
node_modules/
__pycache__/
.venv/
env/
venv/
*.egg-info/

# --- Build Artifacts ---
dist/
build/
out/
.next/
src-tauri/target/
src/tauri/target/

# --- IDE & System ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
*.tmp

# --- Aider / AI Tools ---
.aider*
!.aider.conf.yml
!.aiderignore

# --- Database ---
*.db
*.sqlite
*.sqlite3
data/
qdrant_storage/

# --- Installers (Whitelisted) ---
# Ignore all executables by default...
*.exe
*.msi
*.dmg
*.app

# ...but allow them in the installers folder for distribution
!installers/*.exe
!installers/*.msi
!installers/*.dmg
