{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "includeGitInstructions": false,
  "permissions": {
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rm *)",
      "Bash(git tag *)"
    ],
    "deny": [
      "Bash(git clean *)",
      "Bash(git reset *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q '\\.py$'; then python -m py_compile \"$CLAUDE_FILE_PATH\" 2>&1 || true; fi",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -q '\\.tsx\\?$'; then npx tsc --noEmit --pretty \"$CLAUDE_FILE_PATH\" 2>&1 | head -20 || true; fi",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
