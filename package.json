{
  "scripts": {
    "build": "cd src/frontend && npm run build",
    "dev": "cd src/frontend && npm run dev",
    "build:backend": "powershell -ExecutionPolicy Bypass -File ./scripts/build/build-backend.ps1 -SkipIfUnchanged",
    "tauri:dev": "npx tauri dev --no-watch",
    "tauri:build": "npm run build:backend && npx tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "1.6"
  }
}