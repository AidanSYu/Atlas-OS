# Atlas 2.0 Environment Variables
# ================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit your .env file to version control

# ===========================
# API Keys (Optional - for cloud LLM providers)
# ===========================

# DeepSeek API (https://platform.deepseek.com/api_keys)
# Used for: Aider reasoning agent (DeepSeek R1), cloud LLM fallback
# Format: sk-...
DEEPSEEK_API_KEY=

# MiniMax API (https://platform.minimaxi.com/user-center/basic-information/interface-key)
# Used for: Hybrid Aider coding agent (MiniMax 2.5)
# Format: sk-api-...
MINIMAX_API_KEY=

# OpenAI API (https://platform.openai.com/api-keys)
# Used for: GPT models (optional, Atlas primarily uses local LLMs)
# Format: sk-proj-... or sk-...
OPENAI_API_KEY=

# Anthropic API (https://console.anthropic.com/settings/keys)
# Used for: Claude models (optional, for Discovery OS coordinator)
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# ===========================
# Backend Configuration
# ===========================

# Database URL (default: SQLite in src/backend/)
# DATABASE_URL=sqlite:///./atlas.db

# Data directory for Discovery sessions (default: src/backend/data)
# DATA_DIR=./data
